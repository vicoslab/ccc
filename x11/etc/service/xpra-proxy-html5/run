#!/bin/sh -e

# include configuration file that should do all checks and setup variables
. ./configure.sh

echo '######################################################################################################' #| tee $LOG_DIR/xpra-proxy.log
echo '######################################### STARTED XRPA Proxy #########################################' #| tee $LOG_DIR/xpra-proxy.log
# Force "threaded" (in-process) proxy instances instead of the default per-client child
# process. When the HTML5 client asks the proxy to START a new session (action=start), xpra
# 5.x hands the client socket over to a freshly-spawned child proxy process via fd-passing.
# That handover only works for ssl/wss/ssh client sockets; for a plain "ws" socket - which
# is what we get because FRP terminates TLS upstream and forwards plain HTTP - the handover
# fails ("network IO threads have failed to terminate") and the browser hangs forever at
# "Sending handshake" / "WebSocket connection established". Threaded instances relay the
# connection in-process with no handover, so starting sessions on demand works behind the
# reverse proxy. (This regressed in xpra 5.x; 4.4.x relayed differently.)
export XPRA_PROXY_INSTANCE_THREADED=1

# Use tcp-auth=none (no challenge) rather than tcp-auth=allow. "allow" still issues a
# password challenge but accepts any answer, so it provides no real authentication - yet
# the HTML5 browser client must answer it, and the modern (v6+) client mishandles that
# challenge behind a TLS-terminating reverse proxy, failing with "No password specified
# for authentication challenge". Access control is provided by the front proxy (FRP) and
# the network, not by this challenge, so dropping it loses no real security and lets the
# browser client connect cleanly. The container is single-user, so the proxy still routes
# to / starts the user's session without an authenticated username.
exec chpst -u $USER_NAME xpra proxy :1000 \
						--tcp-auth=none \
						--bind-tcp=0.0.0.0:${XPRA_PROXY_HTML5_PORT} \
						--html=/usr/share/xpra/www \
						--clipboard=GDK --clipboard-direction=both \
						--bell=off --daemon=no >> $LOG_DIR/$HOSTNAME-xpra-proxy.log 2>&1


